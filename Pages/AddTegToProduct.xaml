<Page x:Class="prakt15_Leshukov_TRPO.Pages.AddTegToProduct"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:prakt15_Leshukov_TRPO.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddTegToProduct">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <ListView SelectedItem="{Binding selectedTag}" ItemsSource="{Binding Tags}">
            <ListView.ItemTemplate >
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}"></TextBlock>
                        
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <ComboBox SelectedItem="{Binding tagForProduct}" SelectionChanged="ComboBox_SelectionChanged" ItemsSource="{Binding remainingTags}" DisplayMemberPath="Name"></ComboBox>
            <Button Click="Delete">Удалить</Button>
            <Button Click="Back">Назад</Button>
        </StackPanel>
    </Grid>
</Page>
