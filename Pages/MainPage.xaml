<Page x:Class="prakt15_Leshukov_TRPO.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:prakt15_Leshukov_TRPO.Pages"
      xmlns:convert="clr-namespace:prakt15_Leshukov_TRPO.Converters"
      mc:Ignorable="d" 
      xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Page.Resources>
        <convert:StockConverter x:Key="StockConverter"/>
        <convert:VisibleConverter x:Key="VisibleConverter"/>
        
        
    </Page.Resources>
    
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Grid.ColumnSpan="2">
            <Label>Поиск</Label>
            <TextBox TextChanged="TextBox_TextChanged" Text="{Binding searchQuery, UpdateSourceTrigger=PropertyChanged}" md:HintAssist.Hint="Введите текст для поиска"/>
        </StackPanel>
       

        <ScrollViewer Grid.Row="1" Grid.Column="0" Grid.RowSpan="2">
        <StackPanel  Grid.RowSpan="2">
            <Label FontSize="16">Сортировка</Label>
            <ComboBox x:Name="comboBoxI" SelectionChanged="ComboBox_SelectionChanged">
                <ComboBox.Items>
                    <ComboBoxItem Tag="empty"></ComboBoxItem>
                    <ComboBoxItem Tag="Name">По наименования</ComboBoxItem>
                    <ComboBoxItem Tag="PriceAscend">По цене(по возрастанию)</ComboBoxItem>
                    <ComboBoxItem Tag="PriceDescend">По цене(по убыванию)</ComboBoxItem>
                    <ComboBoxItem Tag="CountAscend">По количеству(по возрастанию)</ComboBoxItem>
                    <ComboBoxItem Tag="CountDescend">По количеству(по убыванию)</ComboBoxItem>
                </ComboBox.Items>
            </ComboBox>
            <Label>Фильтры</Label>
            <ComboBox SelectedValue="{Binding SelectedSearchType, Mode=TwoWay}" 
          SelectedValuePath="Tag" SelectionChanged="ComboBox_SelectionChanged_1">
                <ComboBox.Items>
                    <ComboBoxItem Tag="Category">По категории</ComboBoxItem>
                    <ComboBoxItem Tag="Brand">По бренду</ComboBoxItem>
                    <ComboBoxItem Tag="Price">По цене</ComboBoxItem>
                </ComboBox.Items>
            </ComboBox>
            <TextBox
                 Visibility="{Binding IsCategoryVisible, Converter={StaticResource VisibleConverter }}"
                 Margin="0,5" 
                 md:HintAssist.Hint="Введите название категории"
                 Text="{Binding categoryValue}"
                TextChanged="CategoryTextBox_TextChanged"
                 />
            <TextBox
                 Visibility="{Binding IsBrandVisible, Converter={StaticResource VisibleConverter }}"
                 Margin="0,5" 
                     md:HintAssist.Hint="Введите название бренда"
                 Text="{Binding brandValue}"
                TextChanged="BrandTextBox_TextChanged"
                 />
            <StackPanel Visibility="{Binding IsPriceVisible, Converter={StaticResource VisibleConverter}}">
                
                <Label>от</Label>
                <TextBox  Text="{Binding filterPriceFrom, UpdateSourceTrigger=PropertyChanged}"/>
                <Label>до</Label>
                <TextBox  Text="{Binding filterPriceTo, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <Button Click="Reset" Margin="5">Сбросить</Button>
                <WrapPanel Grid.Row="2" Grid.ColumnSpan="2">
                    <TextBlock Text="{Binding service.Products.Count, StringFormat='{}Всего: {0}'}"/>
                    <TextBlock Text="{Binding Items.Count, ElementName=ProductsList, StringFormat='{} Показано: {0}'}"/>
                </WrapPanel>
                
            
            <Button Visibility="{Binding ButtonVisibility}" Click="goProduct" Margin="5">Создать продукт</Button>
                <Button Visibility="{Binding ButtonVisibility}" Click="goCategory" Margin="5">К категориям</Button>
                <Button Visibility="{Binding ButtonVisibility}" Click="goBrand" Margin="5">К брендам</Button>
                <Button Visibility="{Binding ButtonVisibility}" Click="goTag" Margin="5">К тегам</Button>
            <Button Visibility="{Binding ButtonVisibility}" Click="goTagToProdutc" Margin="5">Добавить Тег к Продукту</Button>
            <Button Visibility="{Binding ButtonVisibility}" Click="Delete" Margin="5">Удалить</Button>
        </StackPanel>
        </ScrollViewer>
        <ListView x:Name="ProductsList" MouseDoubleClick="ListView_MouseDoubleClick" SelectedItem="{Binding selectedItem}" Grid.RowSpan="2" Grid.Row="1" HorizontalContentAlignment="Stretch" Grid.Column="1" ItemsSource="{Binding products}">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#00b4c4"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Stock,Converter={StaticResource StockConverter}}" Value="True">
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="BorderBrush" Value="#ffd129
"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>

                            </Grid.RowDefinitions>
                            <TextBlock HorizontalAlignment="Left" Grid.Row="0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} {1}">

                                        <Binding Path="Brand.Name" />
                                        <Binding Path="Name" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Right" Grid.Row="0">
                                <Run Text="Цена:"/>
                                <Run Text="{Binding Price, StringFormat={}{0:F1}}"/>
                            </TextBlock>
                            <TextBlock Grid.Row="1">
            <Run Text="★"/>
            <Run Text="{Binding Raiting}"/>             
                            </TextBlock>
                            <TextBlock Grid.Row="2">
        <Run Text="Категория"/>
        <Run Text="{Binding Category.Name}"/>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Left" Grid.Row="3">
        <Run Text="Описание"/>
        <Run Text="{Binding Description}"/>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Right" Grid.Row="3">
        <Run Text="Остаток"/>
        <Run Text="{Binding Stock}"/>
                            </TextBlock>

                            <ItemsControl Grid.Row="4" ItemsSource="{Binding Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name, StringFormat=#{0}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>


                        </Grid>

                    </Border>
                    
                    
                    
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
    </Grid>
</Page>
