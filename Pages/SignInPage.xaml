<Page x:Class="prakt15_Leshukov_TRPO.Pages.SignInPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:prakt15_Leshukov_TRPO.Pages"
      mc:Ignorable="d" 
      xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SignInPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0">
            <TextBox Text="{Binding password , UpdateSourceTrigger=PropertyChanged}" md:HintAssist.Hint="Введите пароль" Margin="0 0 0 10" Height="40" Width="600"></TextBox>
            <Button Click="SignManager" Margin="0 10 0 0" Height="40">Войти как менеджер</Button>
        </StackPanel>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1">
            <Button Click="SignUser" Height="40" Width="500">Войти как пользователь</Button>
        </StackPanel>
       
    </Grid>
</Page>
